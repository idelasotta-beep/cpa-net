# ─────────────────────────────────────────────────────────────
# Fase 1 — variables mínimas. Las de redes CPA (Adcombo) y del
# dashboard se agregan en sus fases respectivas.
# Copiá este archivo a .env y completá los valores.
# ─────────────────────────────────────────────────────────────

# Database (Postgres). En dev con docker-compose: el valor de abajo funciona tal cual.
# En producción usar la connection string del Postgres de Railway.
DATABASE_URL="postgresql://cpa:cpa@localhost:5432/cpa_net?schema=public"
# Conexión directa (para migraciones; con poolers como PgBouncer apunta al puerto directo).
DIRECT_URL="postgresql://cpa:cpa@localhost:5432/cpa_net?schema=public"

# Ingesta: secreto compartido con EstrategiasIA para verificar la firma HMAC
# del webhook (header X-Estrategas-Signature: sha256=...). Si se deja vacío,
# la verificación se omite (NO recomendado fuera de desarrollo local).
PLATFORM_WEBHOOK_SECRET=""

# ── Adcombo (Fase 2) ──
ADCOMBO_API_KEY=""                                          # api key de afiliado (pedir al manager)
ADCOMBO_API_BASE_URL="https://api.adcombo.com/api/v2"       # base de create/status
ADCOMBO_OFFER_INFO_URL="https://api.adcombo.com/offer/info/" # catálogo de ofertas
ADCOMBO_DEFAULT_BASE_URL=""                                  # param base_url del create (consultar con AM)
ADCOMBO_DEFAULT_REFERRER=""                                  # param referrer del create

# Auth de los endpoints de jobs/admin (Authorization: Bearer ...)
CRON_SECRET=""

# Máximo de intentos de push a la red antes de marcar el lead como failed
MAX_PUSH_ATTEMPTS="5"

# ── Dashboard auth (Fase 3) ──
DASHBOARD_USER_EMAIL=""            # email para login del dashboard
DASHBOARD_USER_PASSWORD_HASH=""    # hash bcrypt (generar con: npm run hash-password <password>)
SESSION_SECRET=""                  # secreto random para firmar la cookie de sesión

# ── Alertas Telegram (opcional; si vacío, no se envían) ──
TELEGRAM_BOT_TOKEN=""   # token del bot (de @BotFather)
TELEGRAM_CHAT_ID=""     # chat/grupo donde enviar las alertas

# Logging
LOG_LEVEL="info"   # trace | debug | info | warn | error | fatal
